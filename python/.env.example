# ==================================================
# Python Automation Engine — Environment Variables
# Copy this file to .env and fill in your values
# ==================================================

# Strapi CMS
STRAPI_URL=http://localhost:1337
STRAPI_ADMIN_EMAIL=your-admin@email.com
STRAPI_ADMIN_PASSWORD=your-admin-password

# OpenAI API
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini

# Anime fetch settings
ANIME_FETCH_LIMIT=20

# Pollinations AI (no key needed — free service)
POLLINATIONS_URL=https://image.pollinations.ai/prompt/
